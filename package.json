{
  "name": "facil-analytics",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "iniciar": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/iniciar.ps1",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:local": "next start -p 3010",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:import-xlsx": "tsx prisma/import-xlsx.ts",
    "db:studio": "prisma studio",
    "db:backfill-estrutura": "tsx prisma/backfill-estrutura.ts",
    "db:seed-planos": "tsx prisma/seed-planos.ts",
    "db:seed-perfis": "tsx prisma/seed-perfis.ts",
    "cron:expirar-assinaturas": "tsx scripts/cron-expirar-assinaturas.ts",
    "db:promote-admin": "tsx scripts/promote-admin.ts",
    "test": "tsx --test src/lib/lotofacil/__tests__/**/*.test.ts",
    "publicar": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/publicar.ps1",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "next-auth": "^4.24.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
