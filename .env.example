# --- Banco (local: Docker porta 5433; produção: Neon) ---
DATABASE_URL=postgresql://lotofacil:lotofacil@127.0.0.1:5433/lotofacil

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3010
NEXTAUTH_SECRET=gere-um-secret-aleatorio-aqui

# --- Google OAuth (obrigatório em produção) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe (opcional — cobrança Premium) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Admin ---
ADMIN_EMAIL=wagdeaguiar@gmail.com

# --- Loterias API (sync automático de concursos) ---
# LOTERIAS_API_URL=https://loteriascaixa-api.herokuapp.com/api

# --- Desenvolvimento local APENAS (nunca true na Vercel/produção) ---
AUTH_DEV_MODE=true
AUTH_DEV_EMAIL=wagdeaguiar@gmail.com
AUTH_DEV_PREMIUM=true

# PRODUÇÃO (Vercel): use AUTH_DEV_MODE=false e NEXTAUTH_URL=https://seu-app.vercel.app
